// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql" 
  //url      = env("DATABASE_URL")
}

model Product {
  id     Int @id @default(autoincrement())
  name   String
  price String
  terms  String[] @default([])
}
model PassesTitle {
  title String @unique
}
model PurchaseButtonTitle {
  title String @unique
}

model Class {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  title  String
  imageUrl String
  description String
  text1 String
  text2 String
}

model Instructor {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  name        String
  image String
  instagram String
  youTube String
  bioLines String[]
}
